<div class="bg-light px-4 py-5 mb-3">
<%= form_with url: contents_path, method: :get, data: { turbo: false } do |f| %>
    <div class="col-4 mx-auto">
        <%= f.label :keyword, "キーワード", class:"form-label" %>
        <%= f.text_field :keyword, placeholder: "キーワードを入力", value: params[:keyword ], class:"form-control" %>
    </div>
<% end %>
</div>
