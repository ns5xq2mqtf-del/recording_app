<div class="bg-success-subtle px-4 py-5 my-0">
<%= form_with url: contents_path, method: :get, data: { turbo: false } do |f| %>
    <div class="col-4 mx-auto">
        <%= f.label :keyword, "キーワードから探す", class:"form-label mb-0" %>
        <div class="d-flex">
        <%= f.text_field :keyword, placeholder: "キーワードを入力", value: params[:keyword], class:"form-control" %>
        <%= f.submit "検索", class:"btn btn-primary" %>
        </div>
        <%= f.label :tag_name, "タグから探す", class:"form-label mb-0 mt-3" %>
        <div class="d-flex">
            <%= f.text_field :tag_name, placeholder: "タグを入力", value: params[:tag_name], class:"form-control" %>
            <%= f.submit "検索", class:"btn btn-primary" %>
        </div>
    </div>
<% end %>
</div>
