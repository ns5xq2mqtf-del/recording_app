<div class="container col-12 col-md-9">
    <h2 class="my-3">レビュー一覧</h2>
    <% if flash[:notice] %>
        <div class="text-center mt-3 mb-2"><%= flash[:notice] %></div>
    <% end %>
    <table class="table">
        <thead>
            <tr>
            <th class="text-center col-3">作品</th>
            <th class="text-center col-3">作品名</th>
            <th class="text-center col-3">レビュー内容</th>
            <th class="text-center col-2">投稿日時</th>
            <th class="text-center col-1"></th>
            </tr>
        </thead>
        <tbody>
        <% @posts.each do |post| %>
            <tr>
            <td class="text-center col-3">
            <% if post.content.content_image.attached? %>
                <%= image_tag post.content.content_image, size:"200x200", class:"object-fit-cover" %>
            <% else %>
                <%= image_tag "sample_content", size:"200x200", class:"object-fit-cover" %>
            <% end %>
            </td>
            <td class="text-center align-middle col-3"><%= link_to post.content.title, content_path(post.content), class:"text-decoration-none" %></td>
            <td class="text-center align-middle col-3"><%= post.title %></td>
            <td class="text-center align-middle col-2"><%= post.created_at.to_fs(:datetime_jp) %></td>
            <td class="text-center align-middle col-1"><%= link_to "削除", content_post_path(post.content, post), data: {turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class:"btn btn-danger" %></td>
            </tr>
        <% end %>
        <tbody>
    </table>
</div>
