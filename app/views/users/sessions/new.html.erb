<div class="container-fluid">
  <div class="container col-md-4 my-5 bg-body rounded">
  <div class="py-4">
    <h2 class="mb-4 ms-3">ログイン</h2>
    <div class="col-10 mx-auto">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div>
      <%= f.label :email, "メールアドレス" , class:"form-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class:"form-control mb-3" %>
    </div>

    <div>
      <%= f.label :password, "パスワード", class:"form-label" %>
      <%= f.password_field :password, autocomplete: "current-password", class:"form-control mb-3" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="form-check mb-3 d-flex justify-content-center">
      <%= f.check_box :remember_me, class:"form-check-input me-3" %>
      <%= f.label :remember_me, "ログイン状態を保持する", class:"form-check-label" %>
      </div>
    <% end %>

    <div class="text-center">
      <%= f.submit "ログイン", class:"btn btn-secondary px-5" %>
    </div>
    </div>
    <% end %>
    <%= render "users/shared/links" %>
    </div>
</div>
</div>
</div>

