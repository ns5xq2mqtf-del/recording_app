<div class="container-fluid">
  <div class="container col-md-4 mt-5 mb-2 py-4 bg-body rounded">
      <h3 class="mb-4 ms-3">アカウント編集</h3>
      <div class="col-10 mx-auto">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>

        <%= render "users/shared/error_messages", resource: resource %>

      <div class="mb-3">
        <%= f.label :email, "メールアドレス", class:"form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class:"form-control" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <div>Currently waiting confirmation for: <%= resource.unconfirmed_email %></div>
      <% end %>

    <div class="mb-3">
      <%= f.label :password, "パスワード(変更しない場合は空白)", class:"form-label" %>
      <%= f.password_field :password, autocomplete: "new-password", class:"form-control" %>
      <% if @minimum_password_length %>
        <p><%= @minimum_password_length %> 文字以上にしてください</p>
      <% end %>
    </div>

    <div class="mb-3">
      <%= f.label :password_confirmation, "パスワード(確認用)", class:"form-label" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class:"form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :current_password, "現在のパスワード", class:"form-label" %>
      <%= f.password_field :current_password, autocomplete: "current-password", class:"form-control" %>
    </div>

    <div class="d-flex justify-content-between align-items-end">
      <%= link_to "戻る", :back, class:"ms-3" %>
      <%= f.submit "変更する", class:"btn btn-secondary " %>
    </div>
    <% end %>
    </div>
</div>
<div class="d-flex justify-content-center"><%= link_to "退会する", registration_path(resource_name), data: { turbo_method: :delete, turbo_confirm: "本当に退会しますか？" } %></div>
