<% content_for :title, "contents#show" %>
<div class="container-fluid">

    <div class="container bg-body mt-4">
    <div class="mx-auto" style="max-content; width: fit-content;">

    <div class="row justify-content-center">
        <div class="col-auto border text-center">
        <% if @content.content_image.attached? %>
            <%= image_tag @content.content_image, size:"200x250", class:"object-fit-cover" %>
        <% else %>
            <%= image_tag "sample-image", size:"300x460", class:"object-fit-contain" %>
        <% end %>
        </div>

        <div class="col-12 col-md-6 border d-flex flex-column justify-content-between">
        <div class="row">
            <div class="fs-2 my-2"><%= @content.title %></div>
            <div><%= @content.manufacturer %></div>
            <div><%= @content.detail %></div>
        </div>
        </div>
    </div>
  </div>
  <%= link_to "感想を投稿する", new_content_post_path(@content) %>
  </div>

  <div class="container bg-body mt-2 py-2 px-3">
  <div class="fs-4">評価</div>
    <% @posts.each do |post| %>
        <%= post.title %>
        <%= post.body %>
        <%= post.score %>
    <% end %>
    </div>
</div>
