<% content_for :title, "contents#show" %>
<div class="container-fluid">
    <div class="container bg-body col-md-8 col-lg-6 mt-4">
    <div class="row g-0 mx-auto" style="max-width: 800px;">

        <div class="col-auto py-3">
        <% if @content.content_image.attached? %>
            <%= image_tag @content.content_image, size:"200x250", class:"object-fit-cover" %>
        <% else %>
            <%= image_tag "sample_content", size:"250x400", class:"object-fit-contain" %>
        <% end %>
        </div>

        <div class="col px-4 d-flex flex-column justify-content-center">
            <div class="fs-2 my-2"><%= @content.title %></div>
        <div class="mb-3">
          <% @content.tags.each do |tag| %>
            <span class="badge rounded-pill bg-secondary me-1"><%= tag.name %></span>
          <% end %>
        </div>
            <div><%= @content.manufacturer %></div>
            <div><%= @content.detail %></div>

            <div class="text-end mt-auto mb-4">
            <%= link_to "感想を投稿する", new_content_post_path(@content), class: "btn btn-primary" %>
            </div>
        </div>
    </div>


  </div>

  <div class="container bg-body col-md-8 col-lg-6 mt-2 py-2 px-3">
    <div class="fw-bold fs-3 mb-2 border-bottom" >評価</div>
    <% @posts.each do |post| %>
      <div class="border-bottom mb-2 pb-2 col-auto">

      <div class="d-flex justify-content-between align-items-center mb-1">
        <div class="gap-2 d-flex align-items-center">
          <div class="fw-bold fs-5"><%= post.title %></div>
          <div class="fw-bold fs-5 text-warning">(★<%= post.score %>)</div>
        </div>

        <% if post.user == current_user %>
          <%= link_to "削除", content_post_path(@content, post),
                      data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" },
                      class: "btn btn-danger btn-sm" %>
        <% end %>
      </div>

      <div class="text-secondary"><%= post.body %></div>
    </div>
  <% end %>
  </div>
</div>
